{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "../../"
  },
  "include": [
    "src/**/*",
  ],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/prompts"
    }
  ]
}